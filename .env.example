# Frontend (Vite / Web SDK)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Backend (Firebase Functions / Shopify)
APP_BASE_URL=https://admin.example.com
FIREBASE_PROJECT_ID=your-project-id
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_APP_SCOPES=read_orders,read_products,read_customers,read_inventory
SHOPIFY_APP_URL=https://us-central1-your-project.cloudfunctions.net
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
